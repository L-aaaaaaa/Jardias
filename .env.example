# Jardias 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# MiniMax API Key（供应商 minimax）
MINIMAX_API_KEY=your_minimax_api_key_here

# 阿里云 DashScope API Key（供应商 dashscope）
DASHSCOPE_PLAN_API_KEY=your_dashscope_api_key_here

# DeepSeek API Key（供应商 deepseek）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 至少配置一个供应商即可运行
# 详细说明见 library/参考/运行和开发提示.md
